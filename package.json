{
  "name": "pixel-weather-widget",
  "version": "1.1.0",
  "description": "Pixel Art Desktop Widget Ecosystem",
  "author": "trungdzid3",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder -p always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.lofi.pixelwidget",
    "productName": "Pixel Widget",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "trungdzid3",
        "repo": "widget"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
